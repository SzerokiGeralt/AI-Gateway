# ============================================================
# AI Gateway - przykładowy plik konfiguracyjny
# Skopiuj do .env i uzupełnij wartości
# ============================================================

# ---------- Aplikacja ----------
APP_NAME=AI Gateway
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------- Bezpieczeństwo / JWT ----------
# Wygeneruj: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---------- PostgreSQL ----------
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway_secret_change_me
POSTGRES_DB=ai_gateway
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gateway:gateway_secret_change_me@db:5432/ai_gateway

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL_NAME=claude-sonnet-4-5

# ---------- Ollama (lokalna warstwa DLP) ----------
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL_NAME=llama3.1:8b

# ---------- SMTP / alerty ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=alerts@example.com
SMTP_TO=security-team@example.com
SMTP_USE_TLS=true

# ---------- Rate limiting ----------
CHAT_RATE_LIMIT=30/minute

# ---------- Pierwszy admin (opcjonalny seed) ----------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMeNow!
